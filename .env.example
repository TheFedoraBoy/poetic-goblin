# ─── Poetic Goblin Production Configuration ───────────────────
# Copy this to .env and fill in your values

# REQUIRED — Change this!
SECRET_KEY=generate-a-random-64-char-string-here

# ─── Database ─────────────────────────────────────────────────
# Option A: Use DATABASE_URL (easiest — Railway/Render set this automatically)
# DATABASE_URL=postgresql://user:pass@host:5432/poetic_goblin
# DATABASE_URL=mysql://user:pass@host:3306/poetic_goblin

# Option B: Set individual vars
DB_TYPE=postgres  # 'sqlite', 'mysql', or 'postgres'

# PostgreSQL (recommended for Railway/Render)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=poetic_goblin
POSTGRES_PASSWORD=your-postgres-password
POSTGRES_DATABASE=poetic_goblin

# MySQL (alternative)
# MYSQL_HOST=localhost
# MYSQL_PORT=3306
# MYSQL_USER=poetic_goblin
# MYSQL_PASSWORD=your-mysql-password
# MYSQL_DATABASE=poetic_goblin

# ─── File Storage (S3 / Cloudflare R2) ───────────────────────
STORAGE_TYPE=s3
AWS_ACCESS_KEY_ID=your-aws-key
AWS_SECRET_ACCESS_KEY=your-aws-secret
AWS_S3_BUCKET=poetic-goblin-uploads
AWS_S3_REGION=us-east-1
# AWS_S3_CUSTOM_DOMAIN=cdn.yourdomain.com
# For Cloudflare R2:
# AWS_S3_ENDPOINT_URL=https://your-account-id.r2.cloudflarestorage.com

# ─── Email (SMTP) ─────────────────────────────────────────────
EMAIL_TYPE=smtp
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM_NAME=Poetic Goblin
SMTP_FROM_EMAIL=noreply@poeticgoblin.com
SMTP_USE_TLS=true

# ─── App Settings ─────────────────────────────────────────────
BASE_URL=https://yourdomain.com
REQUIRE_EMAIL_VERIFICATION=true
RATELIMIT_ENABLED=true
RATELIMIT_STORAGE_URI=redis://localhost:6379
MAX_UPLOAD_MB=16

# ─── Session Security ────────────────────────────────────────
SESSION_COOKIE_SECURE=true
SESSION_COOKIE_SAMESITE=Lax

# ─── Error Monitoring (Sentry) ───────────────────────────────
# Sign up free at https://sentry.io
# SENTRY_DSN=https://your-dsn@o123.ingest.sentry.io/456
